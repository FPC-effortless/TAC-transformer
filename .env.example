VITE_CONVEX_URL=https://your-bibiere-deployment.convex.cloud

# Use the bundled Convex function names, or change these to match bibi-main.
VITE_CONVEX_ATELIER_QUERY=admin:getAtelierData
VITE_CONVEX_SAVE_SNAPSHOT_MUTATION=admin:saveAtelierData
VITE_CONVEX_ORDERS_QUERY=orders:list
VITE_CONVEX_CLIENTS_QUERY=clients:list
VITE_CONVEX_UPSERT_ORDER_MUTATION=orders:upsertFromAdmin
VITE_CONVEX_UPSERT_CLIENT_MUTATION=clients:upsertFromAdmin
